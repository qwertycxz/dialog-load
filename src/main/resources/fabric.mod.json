{
	"$schema": "https://schemastore.org/fabric.mod",
	"authors": [
		{
			"contact": {
				"GitHub": "$url_github",
				"Ko-fi": "$url_kofi",
				"homepage": "$url_homepage"
			},
			"name": "$developer"
		}
	],
	"contact": {
		"Central": "$central",
		"CurseForge": "$url_curseforge",
		"Modrinth": "$url_modrinth",
		"issues": "$url_issue",
		"sources": "$url_scm"
	},
	"custom": {
		"mc-publish": {
			"curseforge": "$publish_curseforge",
			"modrinth": "$publish_modrinth"
		}
	},
	"depends": {
		"minecraft": "$fabric_minecraft"
	},
	"description": "$description",
	"environment": "server",
	"icon": "$file_icon",
	"id": "$id",
	"license": "$license",
	"mixins": [
		"$file_mixin"
	],
	"name": "$name",
	"version": "$version"
}
